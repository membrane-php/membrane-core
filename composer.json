{
  "name": "membrane/membrane",
  "type": "library",
  "license": "MPL-2.0",
  "autoload": {
    "psr-4": {
      "Membrane\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Membrane\\Tests\\": "tests/",
      "Membrane\\Tests\\Fixtures\\": "tests/fixtures/"
    }
  },
  "require": {
    "php": "^8.4.0",
    "atto/codegen-tools": "^0.1.2",
    "psr/http-message": "^2.0",
    "psr/log": "^3.0",
    "symfony/console": "^7.4 || ^8.4",
    "membrane/openapi-reader": "^3.1",
    "membrane/openapi-router": "0.5.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.0.5",
    "phpstan/phpstan": "^2.1.40",
    "squizlabs/php_codesniffer": "^3.13.5",
    "guzzlehttp/psr7": "^2.9.0",
    "mikey179/vfsstream": "^1.6.12"
  },
  "bin": [
    "bin/membrane"
  ],
  "config": {
    "allow-plugins": {
      "infection/extension-installer": true
    }
  }
}
